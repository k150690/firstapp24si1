<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/catmath"
        android:translationZ="1dp"
        android:orientation="vertical">
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:layout_gravity="center"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/llHeader"
        android:orientation="vertical"
        android:layout_marginTop="-70dp"
        android:translationZ="60dp">

        <LinearLayout
            android:id="@+id/llNama"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:layout_marginBottom="100dp"
            android:background="@drawable/buttonwhite"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textNamaUser"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Budi"
                android:textColor="@color/black"
                android:textSize="12pt" />
            <Button
                android:id="@+id/btnKeluar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:padding="2dp"
                android:background="@color/brown"
                android:text="Keluar">
            </Button>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llLingkaran"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/button"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/lingkaran" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lingkaran"
                android:textColor="@color/white"
                android:textSize="12pt" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llPersegi"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/button"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/lingkaran" />

            <TextView
                android:id="@+id/textView1"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Persegi"
                android:textColor="@color/white"
                android:textSize="12pt" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llSegitiga"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/button"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView31"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/lingkaran" />

            <TextView
                android:id="@+id/textView31"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Segitiga"
                android:textColor="@color/white"
                android:textSize="12pt" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llKeluar"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/button"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/lingkaran" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Segitiga"
                android:textColor="@color/white"
                android:textSize="12pt" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/txvNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copyright © Bangun Ruang 2026"
            android:textAlignment="center"
            android:textSize="7pt" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>